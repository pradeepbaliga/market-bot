# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_chat_id_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Webhook security ──────────────────────────────────────────────────────────
# Set this to any random string — paste it in TradingView alert JSON as "secret"
WEBHOOK_SECRET=changeme_use_a_random_string

# ── Scheduler ─────────────────────────────────────────────────────────────────
BRIEF_HOUR=6
BRIEF_MINUTE=30
TIMEZONE=America/Los_Angeles

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
